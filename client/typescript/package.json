{
  "name": "rosetta-bridge",
  "version": "0.2.3",
  "description": "Request normalization engine for multi-provider inference workloads. Built with JSON Schema and TypeScript adapters.",
  "license": "Apache-2.0",
  "author": "BabySea, Inc. <dev@babysea.ai>",
  "homepage": "https://babysea.ai/blog/how-babysea-built-strict-request-normalization-with-json-schema-and-typescript",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/babysea-community/rosetta-bridge.git",
    "directory": "client/typescript"
  },
  "keywords": [
    "babysea",
    "open-source",
    "ai-infrastructure",
    "control-plane",
    "execution-layer",
    "inference-providers",
    "developer-tools",
    "creative-tools",
    "generative-ai",
    "generative-media",
    "type-safe",
    "request-schema"
  ],
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "rosetta-bridge": "dist/cli.mjs"
  },
  "files": [
    "dist",
    "README.md",
    "NOTICE",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean && tsup src/cli.ts --format esm --dts --clean=false",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.reporter=text --coverage.reporter=lcov --coverage.reporter=cobertura",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@vitest/coverage-v8": "^4.1.5",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=18"
  }
}
